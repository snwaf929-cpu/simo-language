{
  "name": "simo-language-support",
  "displayName": "Simo Language Support",
  "description": "Syntax colors, autocomplete, member intelligence, hovers, diagnostics, symbols, snippets, and file icons for Simo",
  "version": "0.7.0",
  "publisher": "simo-language",
  "icon": "icons/simo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:simo"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "simo",
        "aliases": [
          "Simo",
          "simo"
        ],
        "extensions": [
          ".simo"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/simo.png",
          "dark": "./icons/simo.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "simo",
        "scopeName": "source.simo",
        "path": "./syntaxes/simo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "simo",
        "path": "./snippets/simo.json"
      }
    ]
  }
}
